{
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "https://llm-observability.onrender.com/api/v1/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
