# ==============================================================================
# LLM Command Center - Environment Configurations Template
# ==============================================================================

# ─── System / Infrastructure ──────────────────────────────────────────────────
# Environment state (development, staging, production)
ENVIRONMENT=production

# Database Connection URL (Supabase PostgreSQL with asyncpg driver)
# Format: postgresql+asyncpg://[user]:[password]@[host]:[port]/[dbname]?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?ssl=require

# ─── LLM / AI Providers ───────────────────────────────────────────────────────
# OpenAI API Credentials
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# Ollama Local Service Endpoint (for open-source model proxy)
OLLAMA_API_BASE=http://localhost:11434

# ─── Frontend App (optional overrides) ─────────────────────────────────────────
# Dev/prod API route URL template used by React Axios services
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=LLM Command Center
